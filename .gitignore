# ========================
# TaleForge .gitignore
# ========================

# 环境变量（含 API Key，禁止提交）
.env
.env.local

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# 虚拟环境
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 数据文件（含生成内容，不纳入版本控制）
backend/data/stories.json
backend/data/works.json
backend/data/*.bak
output/
*.png
*.jpg

# 测试缓存
.pytest_cache/

# 日志
*.log

# Playwright 浏览器引擎（测试依赖，组员自行安装）
playwright-browsers/

# Node（前端如需）
node_modules/
dist/
